<div class="card max-w-md mx-auto">
  <h1 class="page-title">Esqueci minha senha</h1>

  <%= form_with url: password_resets_path, method: :post do |f| %>
    <div class="form-field">
      <%= f.label :email, 'E-mail', class: 'form-label' %>
      <%= f.email_field :email, class: 'mt-1 block w-full rounded border border-gray-300 px-3 py-2', required: true, autofocus: true %>
    </div>
    <div class="mt-6">
      <%= f.submit 'Enviar instruções', class: 'btn-primary' %>
    </div>
  <% end %>

  <p class="mt-4 text-sm">
    <%= link_to 'Voltar ao login', new_session_path, class: 'link-plain' %>
  </p>
</div>
