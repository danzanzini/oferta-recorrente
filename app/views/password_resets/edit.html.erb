<div class="card max-w-md mx-auto">
  <h1 class="page-title">Redefinir senha</h1>

  <% if @user.errors.any? %>
    <div class="error-box mb-4">
      <ul class="list-disc list-inside">
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: password_reset_path(params[:token]), method: :patch do |f| %>
    <div class="form-field">
      <%= f.label :password, 'Nova senha', class: 'form-label' %>
      <%= f.password_field :password, class: 'mt-1 block w-full rounded border border-gray-300 px-3 py-2', required: true, autofocus: true %>
    </div>
    <div class="form-field">
      <%= f.label :password_confirmation, 'Confirmar senha', class: 'form-label' %>
      <%= f.password_field :password_confirmation, class: 'mt-1 block w-full rounded border border-gray-300 px-3 py-2', required: true %>
    </div>
    <div class="mt-6">
      <%= f.submit 'Redefinir senha', class: 'btn-primary' %>
    </div>
  <% end %>
</div>
