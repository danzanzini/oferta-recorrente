<% if notice %><p class="notice"><%= notice %></p><% end %>

<div class="flex justify-between items-center mb-6">
  <h1 class="page-title mb-0">Locais de retirada</h1>
  <%= link_to "Novo local", new_location_path, class: "btn-primary" %>
</div>

<div id="locations" class="space-y-4">
  <% @locations.each do |location| %>
    <div class="card">
      <%= render location %>
      <%= link_to "Ver", location, class: "link mt-2 inline-block" %>
    </div>
  <% end %>
</div>
