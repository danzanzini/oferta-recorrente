<% if notice %><p class="notice"><%= notice %></p><% end %>

<div class="card mb-6">
  <%= render @offering %>
</div>

<div class="flex gap-4 items-center">
  <%= link_to "Editar", edit_offering_path(@offering), class: "btn-primary" %>
  <%= link_to "Voltar", offerings_path, class: "link-plain" %>
  <%= button_to "Excluir", @offering, method: :delete, class: "btn-danger" %>
</div>
