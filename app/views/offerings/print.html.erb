<h1>Pedidos — <%= @offering.location.name %></h1>
<p>
  <% if @offering.harvest_at %>
    Colheita: <%= I18n.l(@offering.harvest_at, format: :long) %> &nbsp;|&nbsp;
  <% end %>
  Encerra: <%= I18n.l(@offering.closes_at, format: :short) %>
</p>

<table>
  <thead>
    <tr>
      <th>Apoiador</th>
      <th>Itens pedidos</th>
      <th class="total">Total</th>
    </tr>
  </thead>
  <tbody>
    <% if @harvests.any? %>
      <% @harvests.each do |harvest| %>
        <tr>
          <td><%= harvest.user.name %></td>
          <td><%= harvest_to_string(harvest) %></td>
          <td class="total"><%= harvest.total_items %></td>
        </tr>
      <% end %>
    <% else %>
      <tr><td colspan="3">Nenhum pedido realizado.</td></tr>
    <% end %>
  </tbody>
</table>

<h2>Resumo por produto</h2>
<table>
  <thead>
    <tr>
      <th>Produto</th>
      <th class="total">Total</th>
    </tr>
  </thead>
  <tbody>
    <% @offering.total_harvested.each do |product_name, total| %>
      <tr>
        <td><%= product_name %></td>
        <td class="total"><%= total %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<script>window.print();</script>
