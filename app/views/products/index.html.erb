<% if notice %><p class="notice"><%= notice %></p><% end %>

<div class="flex justify-between items-center mb-6">
  <h1 class="page-title mb-0">Produtos</h1>
  <%= link_to "Novo produto", new_product_path, class: "btn-primary" %>
</div>

<div id="products" class="space-y-4">
  <% @products.each do |product| %>
    <div class="card">
      <%= render product %>
      <%= link_to "Ver", product, class: "link mt-2 inline-block" %>
    </div>
  <% end %>
</div>
