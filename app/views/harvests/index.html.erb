<% if notice %><p class="notice"><%= notice %></p><% end %>

<div class="flex justify-between items-center mb-6">
  <h1 class="page-title mb-0">Colheitas</h1>
  <%= link_to "Nova colheita", new_harvest_path, class: "btn-primary" %>
</div>

<div id="harvests" class="space-y-4">
  <% @harvests.each do |harvest| %>
    <div class="card">
      <%= render harvest %>
      <%= link_to "Ver", harvest, class: "link mt-2 inline-block" %>
    </div>
  <% end %>
</div>
