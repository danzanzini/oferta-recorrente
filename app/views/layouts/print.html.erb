<!DOCTYPE html>
<html>
  <head>
    <title>Imprimir Pedidos — OfertaRecorrente</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <style>
      * { box-sizing: border-box; }
      body { font-family: Arial, sans-serif; font-size: 12pt; margin: 20px; color: #000; background: #fff; }
      h1 { font-size: 16pt; margin: 0 0 4px; }
      h2 { font-size: 13pt; margin: 20px 0 6px; }
      p  { margin: 0 0 12px; font-size: 10pt; color: #555; }
      table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
      th, td { border: 1px solid #ccc; padding: 6px 10px; text-align: left; font-size: 11pt; }
      th { background: #f5f5f5; font-weight: bold; }
      td.total { text-align: right; }
      @media print {
        body { margin: 0; }
        .no-print { display: none !important; }
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
